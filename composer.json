{
    "name": "zakharov-andrew/yii2-poll",
    "description": "Yii2 module for polls with advanced features",
    "type": "yii2-extension",
    "keywords": ["yii2", "poll", "survey", "module", "widget", "yii2-widget"],
    "license": "MIT",
    "authors": [
        {
            "name": "Andrew Zakharov",
            "homepage": "https://github.com/ZakharovAndrew",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/ZakharovAndrew/yii2-poll/issues",
        "source": "https://github.com/ZakharovAndrew/yii2-poll"
    },
    "require": {
        "php": ">=7.4",
        "firebase/php-jwt" : "*"
    },
    "autoload": {
        "psr-4": {
            "ZakharovAndrew\\poll\\": "src"
        }
    },
    "fxp-asset": {
        "enabled": false
    }
}
